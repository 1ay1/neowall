# EditorConfig — consistent whitespace across editors. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,h}]
indent_style = space
indent_size = 4
max_line_length = 100

[meson.build]
indent_style = space
indent_size = 2

[*.{vibe,glsl}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
