# ============================================================================
# NeoWall Configuration File
# ============================================================================
# GPU-Accelerated Animated Wallpapers for Wayland
# "Sets wallpapers until it... doesn't."
#
# This file uses VIBE (Visual Intuitive Bracket Encoding) format
# Specification: https://1ay1.github.io/vibe/
#
# Quick syntax guide:
#   - Objects use { } braces
#   - key value (no = sign needed)
#   - No quotes needed for simple strings
#   - Comments start with #
#   - Hierarchical nesting: output { DP-1 { ... } }
#
# ============================================================================

# ============================================================================
# DEFAULT CONFIGURATION
# ============================================================================
# This section applies to ALL monitors unless overridden in output { } section

default {
    # ========================================================================
    # Wallpaper Configuration
    # ========================================================================

    # Path to wallpaper image or directory
    #
    # DIRECTORY MODE (Recommended!):
    #   - Point to a folder to automatically cycle through ALL images
    #   - Example: path ~/Pictures/wallpapers/
    #   - IMPORTANT: Must end with / for directories!
    #   - Loads all PNG/JPEG files in alphabetical order
    #
    # SINGLE FILE MODE:
    #   - Path to one specific image file
    #   - Example: path ~/Pictures/wallpaper.png
    #
    # Use ~ for home directory, absolute or relative paths
    # Default: Shipped wallpaper (copied to ~/.local/share/neowall/default.png)
    path ~/.local/share/neowall/default.png

    # ========================================================================
    # Shader Configuration (Alternative to static images)
    # ========================================================================

    # Live Shader Wallpaper - GPU-accelerated animated effects
    # Just specify the shader filename - no path needed!
    # Uncomment to use shaders instead of images
    # shader retro_wave.glsl
    #
    # Available shaders (in ~/.config/neowall/shaders/):
    #   - retro_wave.glsl     : Retro synthwave aesthetic with neon colors
    #   - plasma.glsl         : Colorful animated plasma effect
    #   - matrix_rain.glsl    : Matrix-style falling characters
    #   - synthwave.glsl      : Classic 80s synthwave vibes
    #   - fractal_noise.glsl  : Organic fractal patterns
    #   - cyberpunk.glsl      : Neon city skyline
    #
    # You can also use full paths:
    # shader ~/.config/neowall/shaders/retro_wave.glsl
    # shader /usr/share/neowall/shaders/synthwave.glsl
    #
    # NOTE: Use EITHER 'path' OR 'shader', not both!

    # Shader animation speed multiplier
    # Range: 0.1 - 10.0
    # 1.0 = normal speed (default)
    # 2.0 = 2x speed - animations run twice as fast
    # 0.5 = 0.5x speed - animations run at half speed
    # shader_speed 1.0

    # ========================================================================
    # Display Settings
    # ========================================================================

    # Display mode - how wallpaper fills the screen
    # Options:
    #   - fill    : Scale to fill screen, crop if needed (recommended)
    #   - fit     : Scale to fit inside screen, may show borders
    #   - center  : Center without scaling
    #   - stretch : Stretch to fill (may distort aspect ratio)
    #   - tile    : Repeat image to fill screen
    mode fill

    # ========================================================================
    # Cycling Configuration
    # ========================================================================

    # Wallpaper cycling duration in seconds
    # Set to 0 to disable automatic cycling
    # Range: 0 - 86400 (24 hours)
    # Examples:
    #   60    = 1 minute
    #   300   = 5 minutes (recommended for quick rotation)
    #   900   = 15 minutes
    #   1800  = 30 minutes (recommended for work)
    #   3600  = 1 hour
    duration 0

    # ========================================================================
    # Transition Effects
    # ========================================================================

    # Transition effect when changing wallpapers
    # Options:
    #   - none         : Instant switch (no transition)
    #   - fade         : Smooth crossfade (DEFAULT, recommended)
    #   - slide-left   : Slide old image to the left
    #   - slide-right  : Slide old image to the right
    #   - glitch       : Digital glitch effect (cyberpunk style)
    #   - pixelate     : Pixelated mosaic transition
    transition fade

    # Transition duration in milliseconds
    # Range: 100 - 5000
    # Examples:
    #   100  = Fast (snappy)
    #   300  = Default (balanced)
    #   500  = Smooth (recommended for fade)
    #   1000 = Slow (dramatic)
    transition_duration 300
}

# ============================================================================
# PER-MONITOR CONFIGURATION
# ============================================================================
# Override default settings for specific monitors
# Hierarchical structure: output { <monitor-name> { settings... } }
#
# To find your monitor names, run:
#   neowall list-outputs
#
# Or use compositor-specific commands:
#   - Sway:     swaymsg -t get_outputs
#   - Hyprland: hyprctl monitors
#   - Generic:  wlr-randr
#
# Common monitor naming conventions:
#   - Laptop internal:  eDP-1, eDP, LVDS-1
#   - HDMI ports:       HDMI-A-1, HDMI-A-2, HDMI-1
#   - DisplayPort:      DP-1, DP-2, DP-3
#   - DVI:              DVI-D-1, DVI-I-1
#   - VGA:              VGA-1, VGA-2

output {
    # Example 1: Laptop display (commented out by default)
    # eDP-1 {
    #     path ~/Pictures/laptop-wallpaper.jpg
    #     mode fill
    #     duration 0
    # }

    # Example 2: Primary external monitor via HDMI
    # HDMI-A-1 {
    #     path ~/Pictures/monitor-wallpaper.png
    #     mode fit
    #     duration 300
    #     transition fade
    #     transition_duration 500
    # }

    # Example 3: DisplayPort monitor with cycling from directory
    # DP-1 {
    #     path ~/Pictures/Nature/
    #     mode fill
    #     duration 300
    #     transition fade
    #     transition_duration 1000
    # }

    # Example 4: Secondary monitor with shader wallpaper
    # DP-2 {
    #     shader plasma.glsl
    #     shader_speed 1.5
    #     mode fill
    # }

    # Example 5: Vertical/portrait monitor
    # DP-3 {
    #     path ~/Pictures/portrait-wallpaper.png
    #     mode fit
    # }
}

# ============================================================================
# COMPLETE EXAMPLE CONFIGURATIONS
# ============================================================================

# --- Example 1: Simple Single Monitor Setup ---
# default {
#     path ~/Pictures/my-wallpaper.png
#     mode fill
# }

