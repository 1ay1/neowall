#         path ~/Pictures/Gaming/main-screen.png
#         mode fill
#     }
#     DP-2 {
#         path ~/Pictures/Gaming/side-left.png
#         mode fill
#     }
#     DP-3 {
#         path ~/Pictures/Gaming/side-right.png
#         mode fill
#     }
# }

# --- Example 6: Work Setup with Cycling ---
# default {
